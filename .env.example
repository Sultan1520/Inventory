# Copy to .env and adjust as needed: cp .env.example .env

# PostgreSQL
POSTGRES_DB=university_inventory
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# Backend
BACKEND_PORT=8080
JWT_SECRET=UniversityInventorySuperSecretKeyChangeMeInProduction1234567890
SEED_ENABLED=true

# Frontend (host port -> container nginx :80)
FRONTEND_PORT=4200
